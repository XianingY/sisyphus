int main() {
  int n = 24;
  int s = 0;
  int x = 0;
  while (x < n) {
    int y = 0;
    while (y < n) {
      if ((x + y) % 7 == 0) {
        y = y + 1;
        continue;
      }
      s = s + (x * 3 + y * 2) % 11;
      if (s % 97 == 0) break;
      y = y + 1;
    }
    x = x + 1;
  }
  putint(s);
  putch(10);
  return 0;
}
