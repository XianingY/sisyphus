int main() {
  int a[4][5][6];
  int x = 0;
  while (x < 4) {
    int y = 0;
    while (y < 5) {
      int z = 0;
      while (z < 6) {
        a[x][y][z] = 5 + x * 2 + y * 3 + z;
        z = z + 1;
      }
      y = y + 1;
    }
    x = x + 1;
  }

  int s = 0;
  x = 0;
  while (x < 4) {
    int y = 0;
    while (y < 5) {
      int z = 0;
      while (z < 6) {
        s = s + a[x][y][z];
        z = z + 1;
      }
      y = y + 1;
    }
    x = x + 1;
  }

  putint(s);
  putch(10);
  return 0;
}
