int sum2d(int a[][4], int n) {
  int s = 0;
  int i = 0;
  while (i < n) {
    int j = 0;
    while (j < 4) {
      s = s + a[i][j];
      j = j + 1;
    }
    i = i + 1;
  }
  return s;
}
int main() {
  int b[2][4] = {{1, 19, 0, 19 + 1}, {19 + 2}};
  putint(sum2d(b, 2));
  putch(10);
  return 0;
}
